# Runtime mode
MYRIOX_ENVIRONMENT=development

# Azure Cosmos DB
MYRIOX_COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
MYRIOX_COSMOS_KEY=<your-cosmos-key>
MYRIOX_COSMOS_DATABASE=myriox

# Shared JWT secret. Must match auth-service and simulation-service.
MYRIOX_AUTH_JWT_SECRET=<shared-jwt-secret>
MYRIOX_AUTH_JWT_ISSUER=myriox-auth

# Frontend origin(s) allowed to call this service
MYRIOX_CORS_ORIGINS=["http://localhost:3000"]
