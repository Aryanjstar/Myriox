# Runtime mode
MYRIOX_ENVIRONMENT=development

# Azure OpenAI
MYRIOX_AZURE_OPENAI_ENDPOINT=https://<your-azure-openai-resource>.openai.azure.com/
MYRIOX_AZURE_OPENAI_API_KEY=<your-azure-openai-key>
MYRIOX_AZURE_OPENAI_API_VERSION=2024-10-21
MYRIOX_AGENT_REASONING_DEPLOYMENT=agent-reasoning
MYRIOX_REPORT_SYNTHESIS_DEPLOYMENT=report-synthesis
MYRIOX_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Azure Cosmos DB
MYRIOX_COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
MYRIOX_COSMOS_KEY=<your-cosmos-key>
MYRIOX_COSMOS_DATABASE=myriox

# Plan service base URL
MYRIOX_PLAN_SERVICE_URL=http://localhost:8010

# Shared JWT secret. Must match auth-service and plan-service.
MYRIOX_AUTH_JWT_SECRET=<shared-jwt-secret>
MYRIOX_AUTH_JWT_ISSUER=myriox-auth

# Frontend origin(s) allowed to call this service
MYRIOX_CORS_ORIGINS=["http://localhost:3000"]
